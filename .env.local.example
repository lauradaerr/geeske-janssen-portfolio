# Kopiere diese Datei zu .env.local und passe die Werte an.

# Admin-Login (CMS unter /admin)
ADMIN_PASSWORD=geeske
# Geheimnis zum Signieren der Sitzung – beliebige lange Zeichenkette:
ADMIN_SECRET=bitte-hier-eine-lange-zufaellige-zeichenkette-eintragen

# Vercel Blob (nur online nötig – speichert Inhalte & Bild-Uploads).
# Lokal NICHT setzen: ohne diesen Token nutzt der Admin das lokale Dateisystem.
# Online wird er von Vercel automatisch gesetzt, wenn ein Blob-Store mit dem Projekt verbunden ist.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
